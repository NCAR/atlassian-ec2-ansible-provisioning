#!/bin/bash

tag=$1
if [ -z "$tag" ] || [ "$tag" = "-h" ]; then
        cat << USAGE
$0 tag

Backup site for future restore or clone with restore_site.sh script.

Backups will be named for the tag plus a date string, and will be
dumped to the S3 bucket under the key __SITE_FQDN__/backups/.

In order to back up plugins, an admin REST API token must be provided
in AWS secretsmanager. The secret is created by the pulumi stack and
the ARN is listed in the pulumi stack output as "secret
app_api_token_secret_arn". The secret must be manually populated with
the API REST token.

USAGE
   exit 1
fi

script_start=$(date '+%s')
export TMPDIR=/tmp
APP_API_TOKEN_SECRET_ARN="{{ app_api_token_secret_arn }}"

bucket_url="{{ atl_s3_path }}backups/$(date --iso-8601=seconds)-${tag}"
bucket_name=$(echo $bucket_url  | cut -d '/' -f3)

object_tags=$(cat << OBJECT_TAGS | jq -c .
{
  "S3PutObjectTagging": {
    "TagSet": [
      {
        "Key": "created_by",
        "Value": "backup_for_clone.sh"
      },
      {
        "Key": "fqdn",
        "Value": "{{ atl_proxy_name }}"
      },
      {
        "Key": "product_edition",
        "Value": "{{ atl_product_edition }}"
      },
      {
        "Key": "version",
        "Value": "{{ atl_product_version }}"
      },
      {
        "Key": "storage_rule",
        "Value": "{{ s3_backup_storage_rule }}"
      }

    ]
  }
}
OBJECT_TAGS
)

elapsed_time() {
    s_elapsed=$(($(date '+%s') - $1))
    printf '%dh:%dm:%ds\n' $(($s_elapsed/3600)) $(($s_elapsed%3600/60)) $(($s_elapsed%60))
}

echo ">>>> Backing up to $bucket_url at $(date) <<<<"

# Whatever version of the AWS API that mysqlsh is using, it needs
# credentials in env vars instead of the instance role
aws_env_vars=$(/usr/local/bin/aws_env_credentials_from_instance_role.sh)
source $aws_env_vars
rm $aws_env_vars

echo ">>> Copying product version"
echo "{{ atl_product_version }}" | aws s3 cp - "${bucket_url}/VERSION"

#
# Backup plugin list
#
echo '{}' | aws s3 cp - "${bucket_url}/plugins.json" # Default to empty plugin list
if ! systemctl is-active --quiet {{ atl_product_family }}; then
    echo ">>> Can't back up plugins because service isn't running so no access to REST API; continuing anyway"
else
    if test -z $APP_API_TOKEN_SECRET_ARN; then
	echo ">>> Can't back up plugins because APP_API_TOKEN_SECRET_ARN var is not set; continuing anyway"
    else
	export ATL_REST_TOKEN=$(aws secretsmanager get-secret-value --secret-id "${APP_API_TOKEN_SECRET_ARN}" | jq -r '.SecretString')
	if test -z $ATL_REST_TOKEN; then
	    echo ">>> Can't back up plugins because ATL_REST_TOKEN var is empty; continuing anyway"
	else
	    echo ">>> Backing up plugin list"
	    t_start=$(date '+%s')
	    plugins_file=$(mktemp)
	    /usr/local/bin/get_upm_plugins.py {{ atl_proxy_name }} > $plugins_file
	    if test $? -ne 0; then
		echo ">>> !!! FAILED to get plugins; script \"get_upm_plugins.py\" exited with error; continuing anyway"
	    else
		aws s3 cp $plugins_file "${bucket_url}/plugins.json"
		rm $plugins_file
		echo ">>> Finished backing up plugin list; elapsed time: " $(elapsed_time $t_start)
	    fi
	fi
    fi
fi

#
# DB backup
#
bucket_db_path="$(echo $bucket_url  | cut -d '/' -f4-)/database"
mysqlsh_cmd=$(mktemp)
cat << MYSQLSH_CMD >$mysqlsh_cmd
util.dumpSchemas(
  ["{{ atl_jdbc_db_name }}"],
  "$bucket_db_path",
  {
    s3BucketName: "$bucket_name",
    threads: 8,
    compatibility: ["strip_definers"]
  }
)
MYSQLSH_CMD

mycnf=$(/usr/local/bin/create_mycnf.sh)

echo ">>> Backing up database to ${bucket_url}/database"
t_start=$(date '+%s')
mysqlsh --defaults-file=$mycnf --javascript --file=$mysqlsh_cmd > /dev/null 2>&1
mysqlsh_status=$?
rm $mysqlsh_cmd
rm $mycnf

if [ "$mysqlsh_status" != "0" ]; then
    echo "Mysqlsh command failed"
    exit 1
fi
echo ">>> Finished backing up database; elapsed time: " $(elapsed_time $t_start)

#
# Home filesystem backup; use tar to preserve symlinks
#
echo ">>> Backing up home filesystem"
t_start=$(date '+%s')

# Get size of homedir in bytes; should be less when compressed so this is max
homedir="{{ atl_product_home }}"
home_size=$(df --output=used -B 1 $homedir | grep -v Used)
echo ">>> Expected size of home backup (for aws cp): ${home_size}"

tar --one-file-system \
    --directory $homedir \
    --create \
    --use-compress-program='/usr/bin/zstd -T$(nproc)' \
    --file - . | aws s3 cp - "${bucket_url}/home.zst" --expected-size $home_size
echo ">>> Finished backing up home filesystem; elapsed time: " $(elapsed_time $t_start)

#
# Software filesystem backup
#
echo ">>> Backing up product software filesystem"
t_start=$(date '+%s')
productdir="{{ atl_product_installation_base }}"
product_size=$(df --output=used -B 1 $productdir | grep -v Used)
echo ">>> Expected size of product software backup (for aws cp): ${product_size}"
tar --one-file-system \
    --directory $productdir \
    --create \
    --use-compress-program='/usr/bin/zstd -T$(nproc)' \
    --file - . | aws s3 cp - "${bucket_url}/product_software.zst" --expected-size $product_size
echo ">>> Finished backing up product software filesystem; elapsed time: " $(elapsed_time $t_start)

#
# Add tags
#
echo ">>> Adding tags to s3 objects"
t_start=$(date '+%s')
batchtmpfile=$(mktemp)
for bucket_key in $(aws s3 ls --recursive "${bucket_url}/" | awk '{print $4}'); do
    echo "${bucket_name},${bucket_key}" >> $batchtmpfile
done
etag=$(md5sum $batchtmpfile | awk '{print $1}')
s3batchtmpfile="{{ atl_s3_path }}${batchtmpfile:1}" 
aws s3 cp $batchtmpfile $s3batchtmpfile
rm $batchtmpfile

manifest=$(cat << SPEC | jq -c .
{
  "Spec": {
    "Format": "S3BatchOperations_CSV_20180820",
    "Fields": ["Bucket","Key"]
  },
  "Location": {
    "ObjectArn": "arn:aws:s3:::${s3batchtmpfile:5}",
    "ETag": "${etag}"
  }
}
SPEC
)

aws s3control create-job \
    --no-confirmation-required \
    --account-id $(aws sts get-caller-identity | jq -r .Account) \
    --operation "${object_tags}" \
    --report '{"Enabled": false}' \
    --manifest "${manifest}" \
    --priority 0 \
    --role-arn "{{ s3_batch_role_arn }}"

# Deleting this seems to sometimes cause failures; racy?
#aws s3 rm $s3batchtmpfile

echo ">>> Finished adding tags to s3 objects; elapsed time: " $(elapsed_time $t_start)

#
# Finished
#
echo
echo "Total elapsed time: " $(elapsed_time $script_start)
echo "S3 backup URL is: ${bucket_url}"
echo ">>>> Finished at $(date) <<<<"



