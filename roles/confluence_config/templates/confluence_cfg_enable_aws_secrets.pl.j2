#!/usr/bin/perl -w

use English;
use warnings;
use strict;
use XML::Twig;
use File::Temp qw(tempfile);
use File::Copy;

my $xml_file = "{{ atl_product_home }}/confluence.cfg.xml";

my $elements = {
    'com.atlassian.secrets.store.aws.AwsSecretsManagerStore' => 'com.atlassian.secrets.store.aws.AwsSecretsManagerStore',
    'jdbc.password.decrypter.classname' => 'com.atlassian.secrets.store.aws.AwsSecretsManagerStore',
    'hibernate.connection.password' => '{"region": "{{ atl_aws_region }}", "secretId": "{{ arn:aws:secretsmanager:us-east-2:317144351594:secret:app-user-secret-20260323164210963500000001-ZArngv", "secretPointer": "/password"}'
};

my $twig = XML::Twig->new(
    pretty_print => 'indented',
    twig_roots =>
    {
	'confluence-configuration/properties/property' => 1
    }
    );

$twig->parsefile($xml_file);

foreach my $property ( $twig->root->children ) {
	if( defined($elements->{$property->att('name')}) ){
		print(">>>> Deleting " . $property->att('name') . "\n");
		$property->delete;
 	} 
}

while (my ($key, $value) = each %{$elements}) {
    $twig->root->insert_new_elt('last_child', 'property', { 'name' => $key }, $value);
}

my ($tmpfh, $tmpname) = tempfile();

$twig->print($tmpfh);
move($tmpname, $xml_file);

    



